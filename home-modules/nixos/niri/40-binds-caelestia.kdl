    // Caelestia launcher entrypoints.
    Mod+P { spawn "caelestia" "shell" "drawers" "toggle" "launcher"; }
    Mod+Shift+P { spawn "caelestia" "shell" "drawers" "toggle" "launcher"; }

    // Caelestia search modes.
    Mod+V { spawn "caelestia" "clipboard"; }
    Mod+Comma { spawn "caelestia" "shell" "drawers" "toggle" "session"; }
    Mod+Period { spawn "caelestia" "emoji" "-p"; }

    // Caelestia session actions.
    Mod+Ctrl+Escape { spawn "caelestia" "shell" "lock" "lock"; }
    Mod+Ctrl+Q { spawn "caelestia" "shell" "drawers" "toggle" "sidebar"; }

    // Media transport keys.
    XF86AudioPlay { spawn "caelestia" "shell" "mpris" "playPause"; }
    XF86AudioPrev { spawn "caelestia" "shell" "mpris" "previous"; }
    XF86AudioNext { spawn "caelestia" "shell" "mpris" "next"; }

    // Volume keys.
    XF86AudioRaiseVolume { spawn "sh" "-c" "wpctl set-mute @DEFAULT_AUDIO_SINK@ 0; wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+"; }
    XF86AudioLowerVolume { spawn "sh" "-c" "wpctl set-mute @DEFAULT_AUDIO_SINK@ 0; wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"; }
    XF86AudioMute { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
